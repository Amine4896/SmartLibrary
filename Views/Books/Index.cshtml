@{ViewData["Title"] = "Livres";}

<div class="page-header mt-2">
  <div>
    <h1>Livres</h1>
    <p>@Model.Count() livres dans la bibliothèque</p>
  </div>
  <a class="btn btn-primary" asp-action="Create">+ Nouveau livre</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <table class="table-modern">
      <thead>
        <tr>
          <th>Titre</th>
          <th>Auteur</th>
          <th>Catégorie</th>
          <th>Statut</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var book in Model)
        {
          <tr>
            <td><strong>@book.Title</strong></td>
            <td>@book.Author</td>
            <td>@book.Category?.Name</td>
            <td>
              @if (book.IsAvailable)
              {
                <span class="badge-available">Disponible</span>
              }
              else
              {
                <span class="badge-borrowed">Emprunté</span>
              }
            </td>
            <td>
              <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-secondary me-1">Modifier</a>
              <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-secondary me-1">Détails</a>
              <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger">Suppr.</a>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>