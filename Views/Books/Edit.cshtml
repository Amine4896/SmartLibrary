@model SmartLibrary.Models.Book

@{
    ViewData["Title"] = "Modifier le livre";
}

<div class="page-header mt-3">
    <div>
        <h1>Modifier le livre</h1>
        <p>Mettre à jour les informations du livre</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">← Retour à la liste</a>
</div>

<div class="form-card">
    <form asp-action="Edit">

        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

        @* Champ caché obligatoire pour l'ID *@
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Titre</label>
            <input asp-for="Title" class="form-control" placeholder="Ex: Clean Code" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Author" class="form-label">Auteur</label>
            <input asp-for="Author" class="form-control" placeholder="Ex: Robert C. Martin" />
            <span asp-validation-for="Author" class="text-danger small"></span>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="Price" class="form-label">Prix (MAD)</label>
                <input asp-for="Price" class="form-control" placeholder="Ex: 120.00" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="StockQuantity" class="form-label">Quantité en stock</label>
                <input asp-for="StockQuantity" class="form-control" placeholder="Ex: 5" />
                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="CategoryId" class="form-label">Catégorie</label>
            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                <option value="">-- Choisir une catégorie --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <input type="submit" value="Enregistrer les modifications" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
        </div>

    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
